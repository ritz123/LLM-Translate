# Optional: create ".env" in the project root (same folder as package.json) for environment defaults.
# The Electron main process loads it at startup if present (no dotenv package).
#
# Prefer the in-app **Configuration** dialog for API keys, Gemini/Ollama settings, and LLM_PROVIDER.
# Use this file for CI, packaging, or team-wide defaults.

# --- Google Gemini ---
# GEMINI_API_KEY=your-key-here
# GOOGLE_API_KEY=your-key-here
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
# GEMINI_MAX_RETRIES=4

# --- OpenAI ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# --- Ollama (local) ---
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2
# OLLAMA_TIMEOUT_MS=180000

# --- Which backend to use (overridden by Configuration when saved there) ---
# auto | gemini | openai | ollama | mock
# LLM_PROVIDER=auto
