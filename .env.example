# Copy to ".env" in the project root (same folder as package.json).
# Keys are read by the Electron main process only — not the web UI bundle.

# --- Google Gemini ---
# Create a key: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-key-here
# Or use:
# GOOGLE_API_KEY=your-key-here
# Optional model (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# --- OpenAI ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# --- Which backend to use ---
# auto   = try Gemini, then OpenAI, then mock
# gemini | openai | mock
# LLM_PROVIDER=auto
