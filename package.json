{
  "name": "notebookllm-translation-editor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.mjs",
  "scripts": {
    "start": "npm run dev",
    "setup": "bash scripts/setup.sh",
    "build:electron-main": "node scripts/build-electron-main.mjs",
    "dev": "npm run build:electron-main && concurrently -k \"node scripts/build-electron-main.mjs --watch\" \"vite\" \"wait-on tcp:5173 file:dist-electron/main.mjs && cross-env ELECTRON_DEV=1 electronmon .\"",
    "build": "tsc -b && vite build && npm run build:electron-main",
    "desktop": "npm run build && electron ."
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^34.2.0",
    "electronmon": "^2.0.3",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.3",
    "typescript": "~5.7.3",
    "vite": "^6.1.0",
    "wait-on": "^8.0.1"
  }
}
